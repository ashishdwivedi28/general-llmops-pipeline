# ==============================================================================
# GCP Lab Environment Variables
# ==============================================================================
# Copy this file: cp lab_test/.env.lab .env
# Then set your lab-specific values below.
#
# In a GCP lab (Qwiklabs / Cloud Skills Boost):
#   - GCP_PROJECT_ID: shown on the lab info panel (e.g. qwiklabs-gcp-01-xxxx)
#   - GCS_BUCKET: you pick a name, bucket is auto-created by lab_test scripts
#   - NO billing required for: Gemini API, GCS, Cloud Logging in most labs
#   - Vertex AI Vector Search is NOT used — FAISS runs locally instead
# ==============================================================================

# ---- REQUIRED: fill these from your lab info panel ----
GCP_PROJECT_ID=qwiklabs-gcp-01-xxxxxxxxxxxx
GCP_LOCATION=us-central1

# ---- GCS Bucket (will be created if it doesn't exist) ----
# Choose a globally unique name: <your-project-id>-llmops-lab
GCS_BUCKET=qwiklabs-gcp-01-xxxxxxxxxxxx-llmops-lab

# ---- Model (free in GCP lab via Vertex AI) ----
MODEL_NAME=gemini-2.0-flash
EMBEDDING_MODEL=text-embedding-004

# ---- Agent ----
AGENT_NAME=llmops-rag-agent-lab
AGENT_DESCRIPTION=Lab RAG chatbot powered by Gemini + local FAISS

# ---- RAG — leave empty for lab (uses local FAISS instead) ----
RAG_CORPUS_RESOURCE=

# ---- Serving ----
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# ---- Observability — disable for lab ----
ENABLE_TRACING=false

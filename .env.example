# ==============================================================================
# LLMOps Pipeline — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values for your GCP project.
# ==============================================================================

# ---- GCP Project ----
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
# Bucket name should match Terraform convention: {project_id}-llmops-dev
GCS_BUCKET=your-gcp-project-id-llmops-dev

# ---- Agent Configuration ----
AGENT_NAME=llmops-rag-agent
MODEL_NAME=gemini-2.0-flash
EMBEDDING_MODEL=text-embedding-004

# ---- RAG Corpus (Vertex AI RAG Engine) ----
# Format: projects/{project}/locations/{location}/ragCorpora/{corpus_id}
RAG_CORPUS_RESOURCE=
RAG_SIMILARITY_TOP_K=10
RAG_VECTOR_DISTANCE_THRESHOLD=0.5

# ---- Vector Search (auto-discovered from pipeline outputs, or set manually) ----
INDEX_DISPLAY_NAME=llmops-vector-index
ENDPOINT_DISPLAY_NAME=llmops-vector-endpoint
# Set these after Pipeline Phase 1 completes, or leave empty for auto-discovery from GCS
VECTOR_SEARCH_INDEX_ENDPOINT=
VECTOR_SEARCH_DEPLOYED_INDEX_ID=

# ---- Model Registry ----
MODEL_DISPLAY_NAME=llmops-rag-chatbot
SERVING_IMAGE=us-docker.pkg.dev/vertex-ai/prediction/tf2-cpu.2-12:latest

# ---- Evaluation Thresholds ----
RELEVANCE_THRESHOLD=0.70
FAITHFULNESS_THRESHOLD=0.65
TOXICITY_THRESHOLD=0.10

# ---- Monitoring ----
MONITORING_WINDOW_DAYS=7

# ---- Pipeline Artifact Manifest (Online ↔ Offline Bridge) ----
# When enabled, the serving layer reads artifact config from the manifest
# written by pipeline phases, instead of requiring manual env-var overrides.
MANIFEST_ENABLED=true
MANIFEST_APP_ID=llmops-app
MANIFEST_BUCKET=
MANIFEST_REFRESH_INTERVAL=120

# ---- Prompt Registry ----
# Versioned prompt management. Prompts stored at gs://{bucket}/prompts/{app_id}/v{N}.yaml
PROMPT_REGISTRY_ENABLED=true
PROMPT_ACTIVE_VERSION=1

# ---- Model Router ----
# Multi-provider model routing config path
MODELS_CONFIG_PATH=confs/models.yaml

# ---- Observability ----
ENABLE_TRACING=true
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---- API Gateway / Auth ----
GATEWAY_CONFIG_PATH=confs/gateway.yaml
SECRET_MANAGER_ENABLED=false
SECRET_PREFIX=llmops

# ---- BigQuery (cost tracking, feedback) ----
BQ_DATASET=llmops

# ---- Fine-Tuning ----
FINETUNING_CONFIG_PATH=confs/fine_tuning.yaml

# ---- Task Detection ----
APP_CONFIG_PATH=confs/app/hr_chatbot.yaml

# ---- Dashboard ----
SERVING_URL=http://localhost:8080

# ---- Serving ----
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# ---- CI/CD (GitHub Actions) ----
# These are set as GitHub Secrets, not in .env
# WIF_PROVIDER=projects/{project_number}/locations/global/workloadIdentityPools/{pool}/providers/{provider}
# WIF_SERVICE_ACCOUNT=cicd-sa@{project}.iam.gserviceaccount.com
# ARTIFACT_REGISTRY={location}-docker.pkg.dev/{project}/{repo}
